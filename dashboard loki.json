{
  "__inputs": [],
  "__requires": [
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Kubernetes Pod Logs Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🟢 App — Laravel & Nginx",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Laravel App Logs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"app\", container=\"laravel\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Nginx Logs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"app\", container=\"nginx\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "🗄️ Infra — MySQL / Redis / PhpMyAdmin",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "MySQL Logs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"infra\", container=\"mysql\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Redis Logs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"infra\", container=\"redis\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "logs",
      "title": "PhpMyAdmin Logs",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"infra\", container=\"phpmyadmin\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "📊 Monitoring Stack",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      }
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Loki Logs",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{namespace=\"monitoring\", container=\"loki\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "logs",
      "title": "Promtail Logs",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 27
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{namespace=\"monitoring\", container=\"promtail\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "logs",
      "title": "Grafana Logs",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 27
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{namespace=\"monitoring\", container=\"grafana\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "🔍 Log Explorer",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      }
    },
    {
      "id": 41,
      "type": "logs",
      "title": "Search Logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showCommonLabels": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} |~ \"$search\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "📈 Log Volume",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 47
      }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Log Rate by Namespace",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 48
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (namespace) (rate({job=\"kubernetes-pods\"}[1m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Top Container Log Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 48
      },
      "datasource": {
        "type": "loki",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (container) (rate({job=\"kubernetes-pods\"}[1m])))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "kubernetes",
    "loki",
    "logs"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "loki",
        "label": "Datasource",
        "refresh": 1
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values(namespace)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "pod",
        "type": "query",
        "label": "Pod",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values({namespace=~\"$namespace\"}, pod)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        },
        "query": "label_values({namespace=~\"$namespace\", pod=~\"$pod\"}, container)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search Regex",
        "query": ""
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Kubernetes Pod Logs",
  "uid": "k8s-pod-logs-clean",
  "version": 1
}